{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ecc-sdlc.design-component.v1",
  "title": "ECC-SDLC Design Component Schema",
  "description": "A design component represents an architectural element that implements one or more requirements and is used for traceability to tests and estimates.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "description",
    "requirementIds",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^DC-\\d{3}$",
      "description": "Unique design component ID (e.g., DC-001)"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 140
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "service",
        "module",
        "component",
        "api",
        "database",
        "job",
        "integration",
        "ui",
        "infra",
        "library",
        "other"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "approved",
        "deprecated"
      ]
    },
    "requirementIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^REQ-(FUNC|NFUNC|CON)-\\d{3}$"
      },
      "uniqueItems": true,
      "description": "Trace-back links to requirements implemented by this component."
    },
    "responsibilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "interfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind", "description"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["api", "event", "job", "ui", "db", "other"] },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string", "pattern": "^DC-\\d{3}$" },
      "uniqueItems": true
    },
    "dataStores": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "complexity": {
      "type": "string",
      "enum": ["simple", "average", "complex"],
      "description": "FPA complexity level. If absent, the estimator agent derives it from interface, responsibility, and dataStore counts."
    },
    "assignedRole": {
      "type": "string",
      "enum": ["juniorDev", "seniorDev", "architect"],
      "description": "Optional role override for hours-per-FP calculation. Defaults to seniorDev if absent."
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["risk", "mitigation"],
        "properties": {
          "risk": { "type": "string", "minLength": 1 },
          "mitigation": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}

