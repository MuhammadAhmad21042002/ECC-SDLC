{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ecc-sdlc.requirement.v1",
  "title": "ECC-SDLC Requirement Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "title", "description", "priority", "source", "status", "acceptanceCriteria", "traceForward"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^REQ-(FUNC|NFUNC|CON)-\\d{3}$",
      "description": "Unique ID: REQ-FUNC-NNN, REQ-NFUNC-NNN, REQ-CON-NNN"
    },
    "type": {
      "type": "string",
      "enum": ["functional", "non-functional", "constraint"]
    },
    "category": {
      "type": "string",
      "enum": ["performance", "security", "scalability", "usability", "compliance", "availability"],
      "description": "Required when type is non-functional"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "type": "string",
      "enum": ["must", "should", "could", "wont"]
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "description": "Origin: RFP section, stakeholder, meeting date, etc."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "validated", "approved", "deferred", "rejected"]
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^REQ-(FUNC|NFUNC|CON)-\\d{3}$"
      },
      "uniqueItems": true
    },
    "complianceFrameworks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Applicable frameworks (e.g., SBP-2024, PPRA-2024, GDPR, ISO-27001, SAMA-2024)"
    },
    "traceForward": {
      "type": "object",
      "additionalProperties": false,
      "required": ["designComponentIds", "testCaseIds", "costLineItemIds"],
      "properties": {
        "designComponentIds": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^DC-\\d{3}$"
          },
          "uniqueItems": true
        },
        "testCaseIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "costLineItemIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Assumptions made when extracting this requirement. Implicit-source requirements must list at least one."
    },
    "deferralReason": {
      "type": ["string", "null"],
      "description": "Required and non-null when priority is 'wont'. Explains why this requirement is out of scope for this version."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "non-functional"
          }
        }
      },
      "then": {
        "required": ["category"]
      }
    },
    {
      "if": {
        "properties": {
          "priority": {
            "const": "wont"
          }
        }
      },
      "then": {
        "properties": {
          "deferralReason": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["deferralReason"]
      }
    }
  ]
}
