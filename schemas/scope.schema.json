{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ecc-sdlc.scope.v1",
  "title": "ECC-SDLC Scope Schema",
  "description": "Structured scope data extracted by the Business Analyst agent. This is the contract for generating the Scope Document.",
  "type": "object",
  "additionalProperties": false,
  "required": ["projectOverview", "objectives", "inScope", "outOfScope", "stakeholders", "assumptions", "constraints", "risks", "complianceFlags", "deliverables"],
  "properties": {
    "projectName": {
      "type": "string",
      "minLength": 1,
      "description": "Optional enrichment for doc generation (merged before validation)."
    },
    "clientName": {
      "type": "string",
      "minLength": 1,
      "description": "Optional enrichment for doc generation (merged before validation)."
    },
    "preparedBy": {
      "type": "string",
      "minLength": 1,
      "description": "Optional; defaults in render pipeline if omitted."
    },
    "documentVersion": {
      "type": "string",
      "minLength": 1,
      "description": "Optional document version string for cover/footer."
    },
    "generatedDate": {
      "type": "string",
      "minLength": 1,
      "description": "Optional ISO or display date for cover/footer."
    },
    "documentStatus": {
      "type": "string",
      "minLength": 1,
      "description": "Optional cover-line status (e.g. Draft, Under Review)."
    },
    "projectOverview": {
      "type": "string",
      "minLength": 1,
      "description": "2–3 paragraph description of what the project is."
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Business goals the client wants to achieve."
    },
    "inScope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "description"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "In-scope item identifier (format is project-specific)."
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "description": "Features/modules that are explicitly included."
    },
    "outOfScope": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Explicitly excluded items."
    },
    "stakeholders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "role", "organization", "contactType"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "role": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "organization": {
            "type": "string",
            "minLength": 1,
            "maxLength": 140
          },
          "contactType": {
            "type": "string",
            "minLength": 1,
            "description": "How this stakeholder is referenced (e.g., client sponsor, end user, regulator)."
          }
        }
      },
      "description": "Key stakeholders and their roles."
    },
    "assumptions": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Assumptions the team is making."
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["timeline", "budget", "technical", "regulatory"]
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "description": "Constraints (timeline/budget/technical/regulatory)."
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "likelihood", "impact", "mitigation"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "likelihood": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "impact": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "mitigation": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "description": "Risks and mitigations."
    },
    "complianceFlags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "description": "Regulatory frameworks that might apply (e.g., SBP, PPRA, GDPR)."
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "What will be handed over to the client."
    },
    "timeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startDate", "endDate", "milestones"],
      "properties": {
        "startDate": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "YYYY-MM-DD"
        },
        "endDate": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "YYYY-MM-DD"
        },
        "milestones": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["milestone", "date"],
            "properties": {
              "milestone": { "type": "string", "minLength": 1 },
              "date": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                "description": "YYYY-MM-DD"
              }
            }
          }
        }
      },
      "description": "Optional high-level timeline estimate."
    }
  }
}
