{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ecc-sdlc.state.v1",
  "title": "ECC-SDLC State Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "projectId",
    "projectName",
    "clientName",
    "currentPhase",
    "phaseHistory",
    "artifacts",
    "requirements",
    "designComponents",
    "testCases",
    "complianceFlags",
    "traceabilityMatrix"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1,
      "description": "Typically points to ../schemas/sdlc-state.schema.json"
    },
    "projectId": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "projectName": {
      "type": "string",
      "minLength": 1
    },
    "clientName": {
      "type": "string",
      "minLength": 1
    },
    "currentPhase": {
      "type": "string",
      "enum": ["discovery", "requirements", "design", "test-planning", "estimation", "compliance", "proposal"]
    },
    "phaseHistory": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["phase", "startedAt", "completedAt"],
        "properties": {
          "phase": {
            "type": "string",
            "enum": ["discovery", "requirements", "design", "test-planning", "estimation", "compliance", "proposal"]
          },
          "startedAt": {
            "type": "string",
            "minLength": 1
          },
          "completedAt": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "srs", "sds", "sts", "estimate", "proposal", "compliance"],
      "properties": {
        "scope": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/artifact"
            }
          ]
        },
        "srs": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/artifact"
            }
          ]
        },
        "sds": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/artifact"
            }
          ]
        },
        "sts": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/artifact"
            }
          ]
        },
        "estimate": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/artifact"
            }
          ]
        },
        "proposal": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/artifact"
            }
          ]
        },
        "compliance": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/artifact"
            }
          ]
        }
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "$ref": "./requirement.schema.json"
      }
    },
    "designComponents": {
      "type": "array",
      "items": {
        "$ref": "./design-component.schema.json"
      },
      "description": "Design components with trace-back links to REQ-* IDs."
    },
    "testCases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      },
      "description": "Placeholder for Sprint 4+ test-case schema"
    },
    "complianceFlags": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "traceabilityMatrix": {
      "type": "object",
      "additionalProperties": true
    },
    "teamRoles": {
      "type": "array",
      "description": "Role templates used for estimation. Each role defines hours-per-FP for the estimator agent. Written by /scope from user input.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "label", "hoursPerFP"],
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1,
            "description": "Stable role identifier (camelCase). Referenced by rateCard, roleAllocations, and teamProfiles[*].roleKey."
          },
          "label": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable role label shown in documents."
          },
          "hoursPerFP": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "teamProfiles": {
      "type": "array",
      "description": "Optional roster of named team members rendered in the proposal's Team Profiles section. Populated by /scope; read verbatim by /proposal. Each entry's roleKey must match a teamRoles[*].key.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "role", "roleKey", "yearsExperience", "relevantProjects"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable role label. Typically mirrors teamRoles[*].label for the matching roleKey."
          },
          "roleKey": {
            "type": "string",
            "minLength": 1,
            "description": "Cross-reference to teamRoles[*].key. Must match exactly."
          },
          "yearsExperience": {
            "type": "string",
            "minLength": 1,
            "description": "Free-text experience descriptor (e.g. '22 years'). String, not number, to preserve display formatting."
          },
          "relevantProjects": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            ],
            "description": "Semicolon-delimited string or array of project descriptions. Rendered verbatim in proposal table."
          }
        }
      }
    },
    "rateCard": {
      "type": "object",
      "description": "Hourly rates keyed by role key. Keys must match state.json.teamRoles[*].key exactly — any role key defined in teamRoles is valid here. Read by the estimator agent to compute cost figures.",
      "additionalProperties": {
        "$ref": "#/$defs/rateCardEntry"
      }
    },
    "contingencyPct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Contingency percentage as a whole number (e.g. 10 means 10%). Applied to total role cost by the estimator agent."
    },
    "roleAllocations": {
      "type": "object",
      "description": "Optional override for default role allocation percentages. Keys must match state.json.teamRoles[*].key. Values are decimals that should sum to 1.0 (e.g. 0.25 = 25%).",
      "additionalProperties": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    },
    "eccRoot": {
      "type": "string",
      "minLength": 1,
      "description": "Absolute path to the ECC runtime root. Written by /scope Step 1, read by all subsequent pipeline commands."
    },
    "lastSavedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp of the last session save. Written by sdlc-session-end.js hook."
    }
  },
  "$defs": {
    "rateCardEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hourlyRate", "currency"],
      "properties": {
        "hourlyRate": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "version", "hash"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "number",
          "minimum": 1,
          "description": "Artifact version. Pipeline commands use integer major versions (1, 2). The document-version.js hook uses float minor increments (1.1, 1.2) for in-session edits."
        },
        "hash": {
          "type": "string",
          "minLength": 1,
          "description": "Typically sha256:<hex>"
        },
        "createdAt": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        },
        "versionHistory": {
          "type": "array",
          "description": "Cumulative version log appended by pipeline commands and document-version.js hook.",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["version", "date", "author", "changes"],
            "properties": {
              "version": {
                "type": "string",
                "minLength": 1
              },
              "date": {
                "type": "string",
                "minLength": 1
              },
              "author": {
                "type": "string",
                "minLength": 1
              },
              "changes": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string"
              }
            }
          }
        },
        "schemaId": {
          "type": "string",
          "description": "Schema $id used to validate this artifact's data (e.g. ecc-sdlc.sds.v1)."
        },
        "templateId": {
          "type": "string",
          "description": "Template ID used to render this artifact (e.g. ecc-sdlc.sds.v2)."
        }
      }
    }
  }
}
