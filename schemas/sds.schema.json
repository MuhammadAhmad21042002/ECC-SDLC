{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ecc-sdlc.sds.v2",
  "title": "ECC-SDLC SDS Schema v2",
  "description": "Structured SDS data for sds-template.json v4. Supports three-tier diagram pipeline. Both Mermaid source strings (for PNG rendering) and structured diagram objects (for custom SVG fallback) are accepted.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "projectName",
    "clientName",
    "preparedBy",
    "generatedDate",
    "documentVersion",
    "versionHistory",
    "architectureOverviewParagraphs",
    "architectureDecisionsNumbered",
    "architectureDiagramMermaid",
    "designComponents",
    "databaseSchemaIntroParagraphs",
    "databaseErDiagramMermaid",
    "dataFlowDiagramMermaid",
    "databaseTables",
    "apiEndpoints",
    "integrationIntroParagraphs",
    "integrationPointsBullets",
    "securityArchitectureParagraphs",
    "securityAuthParagraphs",
    "securityAuthorizationParagraphs",
    "securityDataProtectionParagraphs",
    "securityAuditLoggingParagraphs",
    "traceabilityMatrixRows"
  ],
  "properties": {
    "projectName": {
      "type": "string",
      "minLength": 1
    },
    "clientName": {
      "type": "string",
      "minLength": 1
    },
    "preparedBy": {
      "type": "string",
      "minLength": 1
    },
    "generatedDate": {
      "type": "string",
      "minLength": 1
    },
    "documentVersion": {
      "type": "string",
      "minLength": 1
    },
    "versionHistory": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version", "date", "author", "changes"],
        "properties": {
          "version": {
            "type": "string",
            "minLength": 1
          },
          "date": {
            "type": "string",
            "minLength": 1
          },
          "author": {
            "type": "string",
            "minLength": 1
          },
          "changes": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string"
          }
        }
      }
    },
    "architectureOverviewParagraphs": {
      "$ref": "#/$defs/stringArrayMin1"
    },
    "architectureDecisionsNumbered": {
      "$ref": "#/$defs/stringArrayMin1"
    },
    "architectureDiagramMermaid": {
      "description": "Mermaid source lines for the system architecture diagram. Used for Tier 1 PNG rendering and Tier 3 code listing fallback.",
      "$ref": "#/$defs/stringArrayMin1"
    },
    "architectureDiagram": {
      "description": "Tier 2 custom SVG input for system architecture. Optional — builder uses defaults if absent.",
      "$ref": "#/$defs/architectureDiagramInput"
    },
    "dataFlowDiagram": {
      "description": "Tier 2 custom SVG input for data flow swimlane. Optional — builder uses defaults if absent.",
      "$ref": "#/$defs/dataFlowDiagramInput"
    },
    "networkDiagram": {
      "description": "Tier 2 custom SVG input for network topology. Optional — builder uses defaults if absent.",
      "$ref": "#/$defs/networkDiagramInput"
    },
    "designComponents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "responsibility", "interfaces", "tracesToReq"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^DC-[0-9]{3}$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "responsibility": {
            "type": "string",
            "minLength": 1
          },
          "interfaces": {
            "type": "string",
            "minLength": 1
          },
          "tracesToReq": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^REQ-(FUNC|NFUNC|CON)-[0-9]{3}$"
            }
          }
        }
      }
    },
    "useCaseDiagram": {
      "description": "Tier 2 custom SVG input for use case diagram. Optional — builder uses defaults if absent.",
      "$ref": "#/$defs/useCaseDiagramInput"
    },
    "flowchartDiagram": {
      "description": "Tier 2 custom SVG input for process flowchart. Optional — builder uses defaults if absent.",
      "$ref": "#/$defs/flowchartDiagramInput"
    },
    "databaseSchemaIntroParagraphs": {
      "$ref": "#/$defs/stringArrayMin1"
    },
    "databaseErDiagramMermaid": {
      "description": "Mermaid erDiagram source lines. Used for Tier 1 PNG rendering and Tier 3 code listing fallback.",
      "$ref": "#/$defs/stringArrayMin1"
    },
    "databaseErDiagram": {
      "description": "Tier 2 custom SVG input for ER diagram with full PK/FK/field/type table rendering. Optional.",
      "$ref": "#/$defs/erDiagramInput"
    },
    "databaseTables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["table", "primaryKey", "fields", "relationships"],
        "properties": {
          "table": {
            "type": "string",
            "minLength": 1
          },
          "primaryKey": {
            "type": "string",
            "minLength": 1
          },
          "fields": {
            "type": "string",
            "minLength": 1
          },
          "relationships": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "apiEndpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["method", "path", "description", "request", "response"],
        "properties": {
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "request": {
            "type": "string",
            "minLength": 1
          },
          "response": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "integrationIntroParagraphs": {
      "$ref": "#/$defs/stringArrayMin1"
    },
    "integrationPointsBullets": {
      "$ref": "#/$defs/stringArrayMin1"
    },
    "securityArchitectureParagraphs": {
      "$ref": "#/$defs/stringArrayMin1"
    },
    "securityAuthParagraphs": {
      "$ref": "#/$defs/stringArrayMin1"
    },
    "securityAuthorizationParagraphs": {
      "$ref": "#/$defs/stringArrayMin1"
    },
    "securityDataProtectionParagraphs": {
      "$ref": "#/$defs/stringArrayMin1"
    },
    "securityAuditLoggingParagraphs": {
      "$ref": "#/$defs/stringArrayMin1"
    },
    "traceabilityMatrixRows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reqId", "requirementTitle", "designComponentIds", "coverage"],
        "properties": {
          "reqId": {
            "type": "string",
            "pattern": "^REQ-(FUNC|NFUNC|CON)-[0-9]{3}$"
          },
          "requirementTitle": {
            "type": "string",
            "minLength": 1
          },
          "designComponentIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^DC-[0-9]{3}$"
            }
          },
          "coverage": {
            "type": ["string", "number"]
          }
        }
      }
    },
    "dataFlowDiagramMermaid": {
      "description": "Mermaid sequenceDiagram source lines for the data flow diagram. Used for Tier 1 PNG rendering.",
      "$ref": "#/$defs/stringArrayMin1"
    }
  },
  "$defs": {
    "stringArrayMin1": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "architectureDiagramInput": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": {
          "type": "string"
        },
        "layers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "services"],
            "properties": {
              "name": {
                "type": "string"
              },
              "services": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "erDiagramInput": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": {
          "type": "string"
        },
        "entities": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "fields"],
            "properties": {
              "name": {
                "type": "string"
              },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "type"],
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string"
                    },
                    "pk": {
                      "type": "boolean"
                    },
                    "fk": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        },
        "relations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "cardinality": {
                "type": "string",
                "examples": ["1:1", "1:N", "N:M"]
              }
            }
          }
        }
      }
    },
    "dataFlowDiagramInput": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": {
          "type": "string"
        },
        "actors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to", "message"],
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": ["sync", "async", "return"]
              },
              "sequence": {
                "type": "number"
              }
            }
          }
        }
      }
    },
    "networkDiagramInput": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": {
          "type": "string"
        },
        "zones": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "nodes"],
            "properties": {
              "name": {
                "type": "string"
              },
              "nodes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "label"],
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "label": {
                      "type": "string"
                    },
                    "type": {
                      "type": "string",
                      "enum": ["server", "db", "firewall", "client", "cloud", "loadbalancer"]
                    }
                  }
                }
              }
            }
          }
        },
        "connections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "protocol": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "useCaseDiagramInput": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": {
          "type": "string"
        },
        "actors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              }
            }
          }
        },
        "useCases": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name"],
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "associations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["actorId", "useCaseId"],
            "properties": {
              "actorId": {
                "type": "string"
              },
              "useCaseId": {
                "type": "string"
              }
            }
          }
        },
        "includes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              }
            }
          }
        },
        "extends": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "flowchartDiagramInput": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": {
          "type": "string"
        },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "properties": {
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": ["start", "end", "process", "decision", "io", "connector"]
              }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "label": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
