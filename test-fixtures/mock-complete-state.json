  "designComponents": [
    {
      "id": "CMP-001",
      "name": "AI Search Engine",
      "type": "service",
      "description": "Vector-based semantic search service using OpenAI embeddings. Handles document indexing, query processing, and ranked result retrieval. Bilingual (Urdu/English) via separate embedding pipelines.",
      "technology": "Node.js, Pinecone, OpenAI API",
      "tracesTo": ["REQ-FUNC-001", "REQ-FUNC-003", "REQ-NFUNC-001"]
    },
    {
      "id": "CMP-002",
      "name": "Authentication Service",
      "type": "service",
      "description": "Stateless JWT-based auth service. Validates CNIC via NADRA regex, enforces MFA via TOTP, manages account lockout, and issues scoped access tokens.",
      "technology": "Node.js, Redis (session store), TOTP",
      "tracesTo": ["REQ-FUNC-002"]
    },
    {
      "id": "CMP-003",
      "name": "Document Ingestion Pipeline",
      "type": "pipeline",
      "description": "Async pipeline for PDF upload, text extraction, chunking, and embedding generation. Writes chunks to vector store and metadata to PostgreSQL.",
      "technology": "Node.js, PDF.js, BullMQ, PostgreSQL",
      "tracesTo": ["REQ-FUNC-003"]
    },
    {
      "id": "CMP-004",
      "name": "Infrastructure & HA Layer",
      "type": "infrastructure",
      "description": "Kubernetes deployment with auto-scaling, health checks, and multi-zone failover. Achieves 99.9% SLA via redundant pods and load balancing.",
      "technology": "Kubernetes, AWS EKS, ALB",
      "tracesTo": ["REQ-NFUNC-002"]
    }
  ],
  "testCases": [
    {
      "id": "TC-001",
      "title": "Natural language search returns ranked results",
      "type": "functional",
      "priority": "must",
      "tracesTo": "REQ-FUNC-001",
      "steps": ["POST /api/search with Urdu query", "Assert status 200", "Assert results array length >= 1", "Assert each result has source citation"],
      "expectedResult": "Ranked results returned within 2s with source citations"
    },
    {
      "id": "TC-002",
      "title": "Search supports bilingual queries",
      "type": "functional",
      "priority": "must",
      "tracesTo": "REQ-FUNC-001",
      "steps": ["Submit Urdu query", "Submit equivalent English query", "Compare result sets"],
      "expectedResult": "Both queries return semantically relevant results"
    },
    {
      "id": "TC-003",
      "title": "Account locks after 5 failed login attempts",
      "type": "functional",
      "priority": "must",
      "tracesTo": "REQ-FUNC-002",
      "steps": ["Attempt login with wrong password 5 times", "Attempt 6th login", "Assert 423 Locked response"],
      "expectedResult": "Account locked, admin email notification sent"
    },
    {
      "id": "TC-004",
      "title": "PDF upload triggers indexing pipeline",
      "type": "functional",
      "priority": "must",
      "tracesTo": "REQ-FUNC-003",
      "steps": ["POST /api/documents with valid PDF", "Assert 202 Accepted", "Poll /api/documents/:id/status until indexed", "Assert status = indexed within 60s"],
      "expectedResult": "Document indexed and searchable within 60 seconds"
    },
    {
      "id": "TC-005",
      "title": "Search p95 latency under load",
      "type": "performance",
      "priority": "must",
      "tracesTo": "REQ-NFUNC-001",
      "steps": ["Run k6 load test with 500 VUs for 5 minutes", "Collect p95 latency"],
      "expectedResult": "p95 < 3000ms, p99 < 6000ms"
    }
  ],
